---
import Navigator from "../components/Navigator.astro";
import "../styles/global.css";
import { siteConfig } from "../site.config";

interface Props {
  title?: string;
  description?: string;
  fileLabel?: string;
}

const { title, description = siteConfig.description, fileLabel } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const pathname = Astro.url.pathname;
const label = fileLabel ?? title ?? "README";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/earth-mark.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/earth-mark.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/earth-mark.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="app-shell">
      <Navigator currentPath={pathname} />
      <section class="file-shell">
        <header class="file-header">
          <div class="file-header-left">
            <button
              class="mobile-menu-btn"
              type="button"
              aria-label="Toggle navigation"
              data-mobile-menu-toggle
            >
              <span class="menu-icon" aria-hidden="true"></span>
            </button>
            <h1>{label}</h1>
          </div>
          <div class="file-header-actions">
            <button
              class="theme-toggle theme-cycle-btn"
              type="button"
              aria-label="Cycle site theme"
              data-theme-toggle
            >
              Dark
            </button>
          </div>
        </header>
        <div class="file-scroll-shell" data-win-scroll-shell>
          <main class="file-body" data-win-scroll-body>
            <slot />
          </main>
          <aside class="win-scrollbar" aria-hidden="true">
            <button class="win-scroll-btn win-scroll-up" type="button" data-scroll-up></button>
            <div class="win-scroll-track" data-scroll-track>
              <div class="win-scroll-thumb" data-scroll-thumb></div>
            </div>
            <button class="win-scroll-btn win-scroll-down" type="button" data-scroll-down></button>
          </aside>
        </div>
        <footer class="file-footer">
          <div class="file-footer-meta">
            <span data-clock-utc-date>UTC ----/--/--</span>
            <span data-clock-utc-time>UTC --:--:--</span>
            <span data-clock-moon>MTC --:--:--</span>
            <a class="footer-source-link" href="https://github.com/primeid/magnuslisleva-tn" target="_blank" rel="noreferrer">
              <span class="footer-source-full">Open sourced code</span>
              <span class="footer-source-short">Source</span>
            </a>
          </div>
        </footer>
      </section>
    </div>

    <script is:inline>
      const root = document.documentElement;
      const storedTheme = localStorage.getItem("theme");
      const themeButton = document.querySelector("[data-theme-toggle]");
      const utcDateNode = document.querySelector("[data-clock-utc-date]");
      const utcTimeNode = document.querySelector("[data-clock-utc-time]");
      const moonTimeNode = document.querySelector("[data-clock-moon]");
      const themeOrder = ["dark", "light", "punk"];
      const lunarEpochMs = Date.UTC(1970, 0, 1, 0, 0, 0);
      const lunarDriftPerEarthDayMs = 58.7 / 1000;
      const formatThemeLabel = (theme) =>
        theme ? theme.charAt(0).toUpperCase() + theme.slice(1) : "Theme";
      const normalizePath = (value) => {
        if (!value) return "/";
        if (value === "/") return "/";
        return value.endsWith("/") ? value.slice(0, -1) : value;
      };
      const formatClockParts = (date, timeZone) => {
        const parts = new Intl.DateTimeFormat("en-CA", {
          timeZone,
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
          hour12: false,
        }).formatToParts(date);

        const get = (type) => parts.find((part) => part.type === type)?.value ?? "00";
        return {
          date: `${get("year")}-${get("month")}-${get("day")}`,
          time: `${get("hour")}:${get("minute")}:${get("second")}`,
        };
      };
      const updateClocks = () => {
        const now = new Date();
        const utc = formatClockParts(now, "UTC");

        if (utcDateNode) utcDateNode.textContent = `UTC ${utc.date}`;
        if (utcTimeNode) utcTimeNode.textContent = `UTC ${utc.time}`;

        if (moonTimeNode) {
          const elapsedDays = (now.getTime() - lunarEpochMs) / 86400000;
          const lunarOffsetMs = elapsedDays * lunarDriftPerEarthDayMs;
          const moonDate = new Date(now.getTime() + lunarOffsetMs);
          const moon = formatClockParts(moonDate, "UTC");
          moonTimeNode.textContent = `MTC ${moon.time}`;
        }
      };
      const initialTheme =
        storedTheme === "light" || storedTheme === "dark" || storedTheme === "punk"
          ? storedTheme
          : "dark";

      root.setAttribute("data-theme", initialTheme);
      if (themeButton) themeButton.textContent = formatThemeLabel(initialTheme);
      updateClocks();
      window.setInterval(updateClocks, 1000);
      themeButton?.addEventListener("animationend", () => {
        themeButton.classList.remove("theme-spin");
      });

      themeButton?.addEventListener("click", () => {
        const currentTheme = root.getAttribute("data-theme");
        const nextTheme = currentTheme
          ? themeOrder[(themeOrder.indexOf(currentTheme) + 1) % themeOrder.length]
          : "dark";
        root.setAttribute("data-theme", nextTheme);
        localStorage.setItem("theme", nextTheme);
        themeButton.textContent = formatThemeLabel(nextTheme);
        themeButton.classList.remove("theme-spin");
        void themeButton.offsetWidth;
        themeButton.classList.add("theme-spin");
      });

      const mobileMenuBtn = document.querySelector("[data-mobile-menu-toggle]");
      const navigatorShell = document.querySelector(".navigator-shell");
      const appShell = document.querySelector(".app-shell");

      mobileMenuBtn?.addEventListener("click", () => {
        const isOpen = appShell?.classList.toggle("mobile-nav-open");
        mobileMenuBtn.setAttribute("aria-expanded", String(!!isOpen));
      });

      navigatorShell?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLAnchorElement)) return;
        const href = target.getAttribute("href");
        if (!href || href.startsWith("#")) return;
        const isFolder = target.hasAttribute("data-folder-link");
        if (isFolder) return;
        appShell?.classList.remove("mobile-nav-open");
        mobileMenuBtn?.setAttribute("aria-expanded", "false");
      });

      const navigationEntry = performance.getEntriesByType("navigation")[0];
      if (navigationEntry && "type" in navigationEntry && navigationEntry.type === "reload") {
        Object.keys(sessionStorage)
          .filter((key) => key.startsWith("folder:"))
          .forEach((key) => sessionStorage.removeItem(key));
      }

      document.querySelectorAll(".folder").forEach((folder) => {
        if (!(folder instanceof HTMLElement)) return;
        const folderId = folder.dataset.folderId;
        if (!folderId) return;
        const storedState = sessionStorage.getItem(`folder:${folderId}`);
        if (storedState === "open") {
          folder.classList.add("is-open");
        }
      });

      document.querySelectorAll("[data-folder-link]").forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const folder = link.closest(".folder");
          if (folder instanceof HTMLElement) {
            const folderId = folder.dataset.folderId;
            const isOpen = folder.classList.toggle("is-open");
            if (folderId) sessionStorage.setItem(`folder:${folderId}`, isOpen ? "open" : "closed");
          }
        });
      });

      document.querySelectorAll("[data-win-scroll-shell]").forEach((shell) => {
        const body = shell.querySelector("[data-win-scroll-body]");
        const track = shell.querySelector("[data-scroll-track]");
        const thumb = shell.querySelector("[data-scroll-thumb]");
        const up = shell.querySelector("[data-scroll-up]");
        const down = shell.querySelector("[data-scroll-down]");

        if (!(body instanceof HTMLElement)) return;
        if (!(track instanceof HTMLElement)) return;
        if (!(thumb instanceof HTMLElement)) return;
        if (!(up instanceof HTMLButtonElement)) return;
        if (!(down instanceof HTMLButtonElement)) return;

        let dragOffset = 0;
        let dragging = false;
        const resizeObserver = new ResizeObserver(() => syncThumb());

        const syncThumb = () => {
          const maxScroll = body.scrollHeight - body.clientHeight;
          const trackHeight = track.clientHeight;

          if (maxScroll <= 0 || trackHeight <= 0) {
            thumb.style.display = "none";
            return;
          }

          thumb.style.display = "block";
          const thumbHeight = Math.max(24, (body.clientHeight / body.scrollHeight) * trackHeight);
          const maxThumbTop = trackHeight - thumbHeight;
          const thumbTop = (body.scrollTop / maxScroll) * maxThumbTop;

          thumb.style.height = `${thumbHeight}px`;
          thumb.style.transform = `translateY(${thumbTop}px)`;
        };

        const scrollByStep = (delta) => {
          body.scrollBy({ top: delta, behavior: "auto" });
        };

        up.addEventListener("click", () => scrollByStep(-56));
        down.addEventListener("click", () => scrollByStep(56));

        track.addEventListener("click", (event) => {
          if (event.target === thumb) return;
          const rect = track.getBoundingClientRect();
          const clickY = event.clientY - rect.top;
          const thumbRect = thumb.getBoundingClientRect();
          const thumbCenter = thumbRect.top - rect.top + thumbRect.height / 2;
          scrollByStep(clickY < thumbCenter ? -body.clientHeight * 0.9 : body.clientHeight * 0.9);
        });

        thumb.addEventListener("pointerdown", (event) => {
          dragging = true;
          dragOffset = event.clientY - thumb.getBoundingClientRect().top;
          thumb.setPointerCapture(event.pointerId);
          event.preventDefault();
        });

        thumb.addEventListener("pointermove", (event) => {
          if (!dragging) return;
          const rect = track.getBoundingClientRect();
          const thumbHeight = thumb.getBoundingClientRect().height;
          const maxThumbTop = rect.height - thumbHeight;
          const nextTop = Math.min(Math.max(0, event.clientY - rect.top - dragOffset), maxThumbTop);
          const ratio = maxThumbTop > 0 ? nextTop / maxThumbTop : 0;
          const maxScroll = body.scrollHeight - body.clientHeight;
          body.scrollTop = ratio * maxScroll;
        });

        const stopDragging = (event) => {
          dragging = false;
          if (thumb.hasPointerCapture(event.pointerId)) {
            thumb.releasePointerCapture(event.pointerId);
          }
        };

        thumb.addEventListener("pointerup", stopDragging);
        thumb.addEventListener("pointercancel", stopDragging);
        body.addEventListener("scroll", syncThumb, { passive: true });
        body.querySelectorAll("img").forEach((image) => {
          if (image instanceof HTMLImageElement) {
            image.addEventListener("load", syncThumb, { passive: true });
          }
        });
        resizeObserver.observe(body);
        resizeObserver.observe(track);
        window.addEventListener("resize", syncThumb);
        syncThumb();
      });
    </script>
  </body>
</html>
