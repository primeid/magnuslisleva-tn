---
import type { CreationEntry, Entry, TextEntry } from "../lib/content";
import TagList from "../components/TagList.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const isCreation = entry.collection === "creations";
const Content = entry.Content;
const creationEntry = isCreation ? (entry as CreationEntry) : undefined;
const textEntry = !isCreation ? (entry as TextEntry) : undefined;
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt} fileLabel={entry.data.title}>
  <article class="entry-page content-area">
    <div class="entry-meta mono">
      <span>{isCreation ? "Creation" : "Text"}</span>
      <span>{entry.data.publishDate.toLocaleDateString("en-US", { dateStyle: "medium" })}</span>
      {textEntry?.data.readingTime && <span>{textEntry.data.readingTime}</span>}
      {creationEntry?.data.creationType && <span>{creationEntry.data.creationType}</span>}
    </div>
    <h1>{entry.data.title}</h1>
    <p class="entry-summary">{entry.data.excerpt}</p>
    <TagList tags={entry.data.tags} />

    {
      entry.data.cover && (
        <div class="media-frame cover">
          <img src={entry.data.cover} alt="" loading="eager" />
        </div>
      )
    }

    {
      creationEntry && (
        <dl class="entry-facts mono">
          {creationEntry.data.stack && creationEntry.data.stack.length > 0 && (
            <div>
              <dt>Stack</dt>
              <dd>{creationEntry.data.stack.join(", ")}</dd>
            </div>
          )}
          {creationEntry.data.externalUrl && (
            <div>
              <dt>Link</dt>
              <dd>
                <a href={creationEntry.data.externalUrl} target="_blank" rel="noreferrer">
                  Open project
                </a>
              </dd>
            </div>
          )}
        </dl>
      )
    }

    <div class="content">
      <Content />
    </div>

    {
      entry.data.gallery.length > 0 && (
        <section class="gallery-block">
          <div class="section-title">
            <h2>Gallery</h2>
          </div>
          <div class="gallery">
            {entry.data.gallery.map((image) => <img src={image} alt="" loading="lazy" />)}
          </div>
        </section>
      )
    }

    {
      creationEntry?.data.embedUrl && (
        <section class="embed-block">
          <div class="section-title">
            <h2>Embed</h2>
          </div>
          <div class="embed-shell">
            <iframe
              src={creationEntry.data.embedUrl}
              title={entry.data.title}
              loading="lazy"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .entry-page {
    display: grid;
    gap: 1rem;
  }

  .entry-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: 0.78rem;
  }

  h1 {
    margin: 0;
    font-family: "IBM Plex Mono", monospace;
    font-size: clamp(1.55rem, 4vw, 2.3rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .entry-summary {
    margin: 0;
  }

  .cover {
    margin-top: 0.5rem;
  }

  .entry-facts {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: var(--text-soft);
  }

  .entry-facts div {
    display: flex;
    gap: 0.5rem;
  }

  dt,
  dd {
    margin: 0;
  }

  .content {
    padding-top: 0.5rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .gallery img {
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .embed-shell {
    aspect-ratio: 16 / 9;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 720px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
