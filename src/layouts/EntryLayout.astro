---
import type { CreationEntry, Entry, TextEntry } from "../lib/content";
import BaseLayout from "./BaseLayout.astro";
import TagList from "../components/TagList.astro";

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const isCreation = entry.collection === "creations";
const Content = entry.Content;
const creationEntry = isCreation ? (entry as CreationEntry) : undefined;
const textEntry = !isCreation ? (entry as TextEntry) : undefined;
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt}>
  <article class="shell entry-page">
    <header class="entry-header">
      <div class="meta mono">
        <span>{isCreation ? "Creation" : "Text"}</span>
        <span>{entry.data.publishDate.toLocaleDateString("en-US", { dateStyle: "long" })}</span>
      </div>
      <div class="hero">
        <div>
          <p class="eyebrow">{isCreation ? "Creation log" : "Text archive"}</p>
          <h1>{entry.data.title}</h1>
          <p class="summary">{entry.data.excerpt}</p>
        </div>
        <aside class="card side">
          <TagList tags={entry.data.tags} />
          {
            creationEntry && (
              <dl class="facts">
                <div>
                  <dt>Type</dt>
                  <dd>{creationEntry.data.creationType}</dd>
                </div>
                {creationEntry.data.stack && creationEntry.data.stack.length > 0 && (
                  <div>
                    <dt>Stack</dt>
                    <dd>{creationEntry.data.stack.join(", ")}</dd>
                  </div>
                )}
                {creationEntry.data.externalUrl && (
                  <div>
                    <dt>Link</dt>
                    <dd>
                      <a href={creationEntry.data.externalUrl} target="_blank" rel="noreferrer">
                        Open project
                      </a>
                    </dd>
                  </div>
                )}
              </dl>
            )
          }
          {
            textEntry?.data.readingTime && (
              <p class="read-time mono">{textEntry.data.readingTime}</p>
            )
          }
        </aside>
      </div>
    </header>

    {
      entry.data.cover && (
        <div class="media-frame cover">
          <img src={entry.data.cover} alt="" loading="eager" />
        </div>
      )
    }

    <div class="content-row">
      <div class="prose content">
        <Content />
      </div>
    </div>

    {
      entry.data.gallery.length > 0 && (
        <section class="gallery-block">
          <div class="section-title">
            <h2>Gallery</h2>
          </div>
          <div class="gallery">
            {entry.data.gallery.map((image) => <img src={image} alt="" loading="lazy" />)}
          </div>
        </section>
      )
    }

    {
      creationEntry?.data.embedUrl && (
        <section class="embed-block card">
          <div class="section-title">
            <h2>Embed</h2>
          </div>
          <div class="embed-shell">
            <iframe
              src={creationEntry.data.embedUrl}
              title={entry.data.title}
              loading="lazy"
              allow="autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .entry-page {
    display: grid;
    gap: 2rem;
    padding-bottom: 4rem;
  }

  .entry-header {
    display: grid;
    gap: 1.2rem;
    padding-top: 1rem;
  }

  .meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: 1.5rem;
    align-items: start;
  }

  h1 {
    margin: 0.5rem 0 1rem;
    font-size: clamp(2.8rem, 8vw, 6rem);
    line-height: 0.95;
    max-width: 14ch;
  }

  .summary {
    max-width: 40rem;
    margin: 0;
    color: var(--text-soft);
    font-size: 1.08rem;
  }

  .side {
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
  }

  .facts {
    display: grid;
    gap: 0.9rem;
    margin: 0;
  }

  .facts div {
    display: grid;
    gap: 0.2rem;
  }

  dt {
    font-family: "IBM Plex Mono", monospace;
    color: var(--text-soft);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
  }

  .read-time {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.8rem;
  }

  .cover {
    max-width: 56rem;
  }

  .content-row {
    display: flex;
    justify-content: center;
  }

  .gallery-block {
    display: grid;
    gap: 1rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .gallery img {
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    background: var(--surface-strong);
  }

  .embed-block {
    padding: 1.2rem;
  }

  .embed-shell {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    h1 {
      max-width: none;
    }

    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
