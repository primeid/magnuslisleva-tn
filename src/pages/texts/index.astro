---
import ArchiveGroup from "../../components/ArchiveGroup.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedTexts, groupEntriesByYear } from "../../lib/content";

const texts = getPublishedTexts();
const grouped = groupEntriesByYear(texts);
---

<BaseLayout title="Texts" description="Short and long-form writing." fileLabel="Texts">
  <section class="content-area">
    <p>
      Short notes and longer essays live here. This replaces the notes and stories split with one
      continuous text archive.
    </p>
    {Object.keys(grouped).length > 1 && (
      <div class="years mono">
        {Object.keys(grouped).map((year) => <a href={`/texts/archive/${year}/`}>{year}</a>)}
      </div>
    )}
    {Object.entries(grouped).map(([year, entries]) => <ArchiveGroup year={year} entries={entries} />)}
  </section>
</BaseLayout>

<style>
  .years {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.5rem 0 1rem;
  }

  .years a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.82rem;
  }
</style>
