---
import { getEntrySlug, getPublishedTexts } from "../../lib/content";
import EntryLayout from "../../layouts/EntryLayout.astro";

export async function getStaticPaths() {
  const texts = getPublishedTexts();
  return texts.map((entry) => ({
    params: { slug: getEntrySlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<EntryLayout entry={entry} />
