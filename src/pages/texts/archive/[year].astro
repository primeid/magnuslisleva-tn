---
import EntryCard from "../../../components/EntryCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPublishedTexts, groupEntriesByYear } from "../../../lib/content";

export async function getStaticPaths() {
  const texts = getPublishedTexts();
  const grouped = groupEntriesByYear(texts);
  return Object.entries(grouped).map(([year, entries]) => ({
    params: { year },
    props: { year, entries },
  }));
}

const { year, entries } = Astro.props;
---

<BaseLayout title={`Texts ${year}`} description={`Texts from ${year}.`} fileLabel={`Texts ${year}`}>
  <section class="content-area">
    <p>Text archive for <strong>{year}</strong>.</p>
    <div class="stack listing-grid">
      {entries.map((entry) => <EntryCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
