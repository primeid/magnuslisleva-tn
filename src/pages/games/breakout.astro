---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Breakout" description="Classic brick breaker game." fileLabel="Breakout">
  <section class="content-area game-page">
    <p>Arrow keys or drag to move the paddle. Press space to launch. Tap and drag on mobile.</p>
    <div class="game-shell media-frame">
      <canvas
        class="breakout-board"
        width="384"
        height="448"
        aria-label="Breakout game board"
        data-breakout-board
      ></canvas>
      <div class="game-meta mono">
        <span data-breakout-score>Score 0</span>
        <span data-breakout-lives>Lives 3</span>
        <span data-breakout-status>Press space</span>
      </div>
    </div>
  </section>

  <script is:inline>
    const canvas = document.querySelector("[data-breakout-board]");
    const scoreNode = document.querySelector("[data-breakout-score]");
    const livesNode = document.querySelector("[data-breakout-lives]");
    const statusNode = document.querySelector("[data-breakout-status]");

    if (canvas instanceof HTMLCanvasElement) {
      const ctx = canvas.getContext("2d");
      const W = canvas.width;
      const H = canvas.height;
      const rootStyles = getComputedStyle(document.documentElement);

      const palette = () => ({
        bg: rootStyles.getPropertyValue("--panel").trim() || "#101511",
        line: rootStyles.getPropertyValue("--line").trim() || "#2a3a2d",
        paddle: rootStyles.getPropertyValue("--accent").trim() || "#8bb49a",
        ball: rootStyles.getPropertyValue("--accent-strong").trim() || "#d5f6d7",
        text: rootStyles.getPropertyValue("--text-soft").trim() || "#9fb0a3",
        brickColors: [
          rootStyles.getPropertyValue("--accent-strong").trim() || "#d5f6d7",
          rootStyles.getPropertyValue("--accent").trim() || "#8bb49a",
          rootStyles.getPropertyValue("--text-soft").trim() || "#9fb0a3",
          rootStyles.getPropertyValue("--line-strong").trim() || "#35473a",
        ],
      });

      const PADDLE_W = 60;
      const PADDLE_H = 10;
      const BALL_R = 5;
      const BRICK_ROWS = 6;
      const BRICK_COLS = 8;
      const BRICK_PAD = 4;
      const BRICK_TOP = 50;
      const BRICK_W = (W - BRICK_PAD * (BRICK_COLS + 1)) / BRICK_COLS;
      const BRICK_H = 14;

      let paddle, ball, bricks, score, lives, running, launched, level;

      const initState = () => {
        paddle = { x: W / 2 - PADDLE_W / 2, y: H - 30 };
        ball = { x: W / 2, y: paddle.y - BALL_R - 1, dx: 3, dy: -3 };
        score = 0;
        lives = 3;
        running = false;
        launched = false;
        level = 1;
        spawnBricks();
      };

      const spawnBricks = () => {
        bricks = [];
        for (let r = 0; r < BRICK_ROWS; r++) {
          for (let c = 0; c < BRICK_COLS; c++) {
            bricks.push({
              x: BRICK_PAD + c * (BRICK_W + BRICK_PAD),
              y: BRICK_TOP + r * (BRICK_H + BRICK_PAD),
              alive: true,
              row: r,
            });
          }
        }
      };

      const resetBall = () => {
        ball.x = paddle.x + PADDLE_W / 2;
        ball.y = paddle.y - BALL_R - 1;
        ball.dx = 3 * (Math.random() > 0.5 ? 1 : -1);
        ball.dy = -3;
        launched = false;
      };

      const keys = {};
      window.addEventListener("keydown", (e) => {
        keys[e.key] = true;
        if (e.key === " ") {
          e.preventDefault();
          if (!running) { running = true; updateMeta(); }
          else if (!launched) { launched = true; }
        }
      });
      window.addEventListener("keyup", (e) => { keys[e.key] = false; });

      let touchActive = false;
      let touchX = 0;

      canvas.addEventListener("touchstart", (e) => {
        e.preventDefault();
        if (!running) { running = true; updateMeta(); return; }
        if (!launched) { launched = true; }
        touchActive = true;
        const rect = canvas.getBoundingClientRect();
        touchX = (e.touches[0].clientX - rect.left) / rect.width * W;
      }, { passive: false });

      canvas.addEventListener("touchmove", (e) => {
        e.preventDefault();
        if (!touchActive) return;
        const rect = canvas.getBoundingClientRect();
        touchX = (e.touches[0].clientX - rect.left) / rect.width * W;
        paddle.x = Math.max(0, Math.min(W - PADDLE_W, touchX - PADDLE_W / 2));
      }, { passive: false });

      canvas.addEventListener("touchend", (e) => {
        e.preventDefault();
        touchActive = false;
      }, { passive: false });

      const updateMeta = () => {
        if (scoreNode) scoreNode.textContent = `Score ${score}`;
        if (livesNode) livesNode.textContent = `Lives ${lives}`;
        if (statusNode) {
          if (!running && lives <= 0) statusNode.textContent = "Game over";
          else if (!running) statusNode.textContent = "Press space";
          else if (!launched) statusNode.textContent = "Launch!";
          else statusNode.textContent = `Level ${level}`;
        }
      };

      const paint = () => {
        const c = palette();
        ctx.fillStyle = c.bg;
        ctx.fillRect(0, 0, W, H);

        bricks.forEach((b) => {
          if (!b.alive) return;
          const colorIdx = Math.min(b.row, c.brickColors.length - 1);
          ctx.fillStyle = c.brickColors[colorIdx];
          ctx.fillRect(b.x, b.y, BRICK_W, BRICK_H);
          ctx.strokeStyle = c.bg;
          ctx.lineWidth = 1;
          ctx.strokeRect(b.x, b.y, BRICK_W, BRICK_H);
        });

        ctx.fillStyle = c.paddle;
        ctx.fillRect(paddle.x, paddle.y, PADDLE_W, PADDLE_H);

        ctx.fillStyle = c.ball;
        ctx.beginPath();
        ctx.arc(ball.x, ball.y, BALL_R, 0, Math.PI * 2);
        ctx.fill();

        if (!running && lives > 0) {
          ctx.fillStyle = c.text;
          ctx.font = "14px 'IBM Plex Mono', monospace";
          ctx.textAlign = "center";
          ctx.fillText("PRESS SPACE OR TAP TO START", W / 2, H / 2 + 40);
        }
      };

      const tick = () => {
        if (!running) { paint(); return; }

        const speed = 5;
        if (keys["ArrowLeft"] || keys["a"] || keys["A"]) {
          paddle.x = Math.max(0, paddle.x - speed);
        }
        if (keys["ArrowRight"] || keys["d"] || keys["D"]) {
          paddle.x = Math.min(W - PADDLE_W, paddle.x + speed);
        }

        if (!launched) {
          ball.x = paddle.x + PADDLE_W / 2;
          ball.y = paddle.y - BALL_R - 1;
          updateMeta();
          paint();
          return;
        }

        ball.x += ball.dx;
        ball.y += ball.dy;

        if (ball.x - BALL_R <= 0) { ball.x = BALL_R; ball.dx = Math.abs(ball.dx); }
        if (ball.x + BALL_R >= W) { ball.x = W - BALL_R; ball.dx = -Math.abs(ball.dx); }
        if (ball.y - BALL_R <= 0) { ball.y = BALL_R; ball.dy = Math.abs(ball.dy); }

        if (ball.y + BALL_R >= paddle.y &&
            ball.y + BALL_R <= paddle.y + PADDLE_H + 4 &&
            ball.x >= paddle.x - BALL_R &&
            ball.x <= paddle.x + PADDLE_W + BALL_R) {
          ball.dy = -Math.abs(ball.dy);
          const hitPos = (ball.x - paddle.x) / PADDLE_W;
          ball.dx = (hitPos - 0.5) * 7;
          ball.y = paddle.y - BALL_R - 1;
        }

        if (ball.y - BALL_R > H) {
          lives--;
          if (lives <= 0) {
            running = false;
          } else {
            resetBall();
          }
          updateMeta();
          paint();
          return;
        }

        bricks.forEach((b) => {
          if (!b.alive) return;
          if (ball.x + BALL_R > b.x &&
              ball.x - BALL_R < b.x + BRICK_W &&
              ball.y + BALL_R > b.y &&
              ball.y - BALL_R < b.y + BRICK_H) {
            b.alive = false;
            score += (BRICK_ROWS - b.row) * 10;

            const overlapLeft = ball.x + BALL_R - b.x;
            const overlapRight = b.x + BRICK_W - (ball.x - BALL_R);
            const overlapTop = ball.y + BALL_R - b.y;
            const overlapBottom = b.y + BRICK_H - (ball.y - BALL_R);
            const minOverlap = Math.min(overlapLeft, overlapRight, overlapTop, overlapBottom);

            if (minOverlap === overlapTop || minOverlap === overlapBottom) {
              ball.dy = -ball.dy;
            } else {
              ball.dx = -ball.dx;
            }
          }
        });

        if (bricks.every((b) => !b.alive)) {
          level++;
          spawnBricks();
          resetBall();
          const spd = Math.min(5, 3 + level * 0.3);
          ball.dx = spd * (Math.random() > 0.5 ? 1 : -1);
          ball.dy = -spd;
        }

        updateMeta();
        paint();
      };

      initState();
      updateMeta();
      paint();
      window.setInterval(tick, 1000 / 60);
    }
  </script>
</BaseLayout>

<style>
  .game-page {
    display: grid;
    gap: 1rem;
  }

  .game-shell {
    width: min(100%, 28rem);
    padding: 0.9rem;
  }

  .breakout-board {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--line);
    background: #101511;
    touch-action: none;
  }

  .game-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.8rem;
    font-size: 0.82rem;
    color: var(--text-soft);
  }
</style>
