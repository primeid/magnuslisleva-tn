---
import BaseLayout from "../../layouts/BaseLayout.astro";

const games = [
  { title: "Snake", href: "/games/snake/", description: "Classic snake. Eat, grow, survive." },
  { title: "Space Invaders", href: "/games/space-invaders/", description: "Defend earth from waves of alien invaders." },
  { title: "Tamagotchi", href: "/games/tamagotchi/", description: "Feed, play, and care for a virtual pet." },
  { title: "Breakout", href: "/games/breakout/", description: "Bounce a ball to smash rows of bricks." },
];
---

<BaseLayout title="Games" description="Playable games tucked into the site." fileLabel="Games">
  <section class="content-area">
    <p>Small games built into the site. All playable on desktop and mobile.</p>
    <div class="game-list">
      {games.map((game) => (
        <a class="game-card" href={game.href}>
          <span class="game-icon mono">EXE</span>
          <div>
            <strong class="mono">{game.title}</strong>
            <p>{game.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .game-list {
    display: grid;
    gap: 0.5rem;
  }

  .game-card {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    text-decoration: none;
    position: relative;
  }

  .game-card:hover {
    border-color: var(--line-strong);
    background: var(--accent-soft);
  }

  .game-icon {
    color: var(--text-soft);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-shrink: 0;
    width: 2.4rem;
  }

  strong {
    font-size: 0.88rem;
    font-weight: 500;
  }

  p {
    margin: 0.25rem 0 0;
    color: var(--text-soft);
    font-size: 0.82rem;
    line-height: 1.4;
  }
</style>
