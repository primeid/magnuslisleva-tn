---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Snake" description="Classic snake game." fileLabel="Snake">
  <section class="content-area game-page">
    <p>Arrow keys or WASD to move. Press space to start. Swipe on mobile.</p>
    <div class="game-shell media-frame">
      <canvas
        class="snake-board"
        width="384"
        height="384"
        aria-label="Snake game board"
        data-snake-board
      ></canvas>
      <div class="game-meta mono">
        <span data-snake-score>Score 0</span>
        <span data-snake-status>Press space</span>
      </div>
    </div>
  </section>

  <script is:inline>
    const canvas = document.querySelector("[data-snake-board]");
    const scoreNode = document.querySelector("[data-snake-score]");
    const statusNode = document.querySelector("[data-snake-status]");

    if (canvas instanceof HTMLCanvasElement) {
      const ctx = canvas.getContext("2d");
      const gridSize = 16;
      const tileSize = canvas.width / gridSize;
      const rootStyles = getComputedStyle(document.documentElement);
      const initialSnake = [
        { x: 8, y: 8 },
        { x: 7, y: 8 },
        { x: 6, y: 8 },
      ];

      let snake = initialSnake.map((s) => ({ ...s }));
      let direction = { x: 1, y: 0 };
      let nextDirection = { x: 1, y: 0 };
      let food = { x: 11, y: 8 };
      let score = 0;
      let running = false;

      const palette = () => ({
        board: rootStyles.getPropertyValue("--panel").trim() || "#101511",
        grid: rootStyles.getPropertyValue("--line").trim() || "#2a3a2d",
        food: rootStyles.getPropertyValue("--accent-strong").trim() || "#d5f6d7",
        head: rootStyles.getPropertyValue("--accent").trim() || "#8bb49a",
        body: rootStyles.getPropertyValue("--text-soft").trim() || "#5c8b67",
      });

      const randomFood = () => {
        while (true) {
          const c = {
            x: Math.floor(Math.random() * gridSize),
            y: Math.floor(Math.random() * gridSize),
          };
          if (!snake.some((s) => s.x === c.x && s.y === c.y)) return c;
        }
      };

      const paint = () => {
        if (!ctx) return;
        const c = palette();
        ctx.fillStyle = c.board;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = c.grid;
        ctx.lineWidth = 1;
        for (let i = 0; i <= gridSize; i++) {
          const o = i * tileSize;
          ctx.beginPath(); ctx.moveTo(o, 0); ctx.lineTo(o, canvas.height); ctx.stroke();
          ctx.beginPath(); ctx.moveTo(0, o); ctx.lineTo(canvas.width, o); ctx.stroke();
        }
        ctx.fillStyle = c.food;
        ctx.fillRect(food.x * tileSize + 4, food.y * tileSize + 4, tileSize - 8, tileSize - 8);
        snake.forEach((s, i) => {
          ctx.fillStyle = i === 0 ? c.head : c.body;
          ctx.fillRect(s.x * tileSize + 2, s.y * tileSize + 2, tileSize - 4, tileSize - 4);
        });
      };

      const updateMeta = () => {
        if (scoreNode) scoreNode.textContent = `Score ${score}`;
        if (statusNode) statusNode.textContent = running ? "Running" : score > 0 ? "Game over" : "Press space";
      };

      const reset = () => {
        snake = initialSnake.map((s) => ({ ...s }));
        direction = { x: 1, y: 0 };
        nextDirection = { x: 1, y: 0 };
        food = randomFood();
        score = 0;
        running = true;
        updateMeta();
        paint();
      };

      const tick = () => {
        if (!running) return;
        direction = nextDirection;
        const head = { x: snake[0].x + direction.x, y: snake[0].y + direction.y };
        if (head.x < 0 || head.y < 0 || head.x >= gridSize || head.y >= gridSize ||
            snake.some((s) => s.x === head.x && s.y === head.y)) {
          running = false;
          updateMeta();
          paint();
          return;
        }
        snake.unshift(head);
        if (head.x === food.x && head.y === food.y) {
          score += 1;
          food = randomFood();
        } else {
          snake.pop();
        }
        updateMeta();
        paint();
      };

      const setDirection = (x, y) => {
        if (direction.x === -x && direction.y === -y) return;
        nextDirection = { x, y };
      };

      window.addEventListener("keydown", (e) => {
        if (e.key === "ArrowUp" || e.key === "w" || e.key === "W") setDirection(0, -1);
        if (e.key === "ArrowDown" || e.key === "s" || e.key === "S") setDirection(0, 1);
        if (e.key === "ArrowLeft" || e.key === "a" || e.key === "A") setDirection(-1, 0);
        if (e.key === "ArrowRight" || e.key === "d" || e.key === "D") setDirection(1, 0);
        if (e.key === " ") { e.preventDefault(); reset(); }
      });

      let touchStartX = 0;
      let touchStartY = 0;
      canvas.addEventListener("touchstart", (e) => {
        e.preventDefault();
        if (!running) { reset(); return; }
        const t = e.touches[0];
        touchStartX = t.clientX;
        touchStartY = t.clientY;
      }, { passive: false });

      canvas.addEventListener("touchend", (e) => {
        e.preventDefault();
        const t = e.changedTouches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        if (Math.abs(dx) < 10 && Math.abs(dy) < 10) return;
        if (Math.abs(dx) > Math.abs(dy)) {
          setDirection(dx > 0 ? 1 : -1, 0);
        } else {
          setDirection(0, dy > 0 ? 1 : -1);
        }
      }, { passive: false });

      updateMeta();
      paint();
      window.setInterval(tick, 115);
      window.setInterval(() => { if (!running) paint(); }, 500);
    }
  </script>
</BaseLayout>

<style>
  .game-page {
    display: grid;
    gap: 1rem;
  }

  .game-shell {
    width: min(100%, 28rem);
    padding: 0.9rem;
  }

  .snake-board {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--line);
    background: #101511;
    image-rendering: pixelated;
    touch-action: none;
  }

  .game-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.8rem;
    font-size: 0.82rem;
    color: var(--text-soft);
  }
</style>
