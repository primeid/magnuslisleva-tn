---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPublishedEntries, getUniqueTags, slugifyTag } from "../../lib/content";

const entries = getAllPublishedEntries();
const tags = getUniqueTags(entries);
---

<BaseLayout title="Tags" description="Explore texts and creations by tag." fileLabel="Tags">
  <section class="content-area">
    <p>Browse the archive through themes and media types.</p>
    <div class="tag-grid">
      {tags.map((tag) => <a class="tag tag-link" href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>)}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-grid {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .tag-link {
    font-size: 0.9rem;
  }
</style>
