---
import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  filterByTag,
  getAllPublishedEntries,
  getUniqueTags,
  slugifyTag,
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = getAllPublishedEntries();
  return getUniqueTags(entries).map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allEntries = getAllPublishedEntries();
const entries = filterByTag(allEntries, tag);
---

<BaseLayout title={tag} description={`Entries tagged ${tag}.`} fileLabel={`Tag: ${tag}`}>
  <section class="content-area">
    <p>Entries tagged <strong>{tag}</strong>.</p>
    <div class="stack listing-grid">
      {entries.map((entry) => <EntryCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
