---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedCreations, getPublishedTexts } from "../lib/content";

const texts = getPublishedTexts();
const creations = getPublishedCreations();
const recentTexts = texts.slice(0, 4);
const recentCreations = creations.slice(0, 4);
---

<BaseLayout fileLabel="README">
  <article class="content-area readme-page">
    <figure class="readme-figure media-frame">
      <img src="/media/forest-notebook/forest-cover.svg" alt="Botanical cover study" />
    </figure>
    <p>Howdy. Magnus here.</p>
    <p>
      <strong>MagnusLisleva.tn</strong> is a personal archive for texts, field notes, software,
      music, photos, and other creations. The structure borrows from code and file browsers, but
      the subject matter leans toward biology, philosophy, politics, AI, and music.
    </p>
    <p>
      This is the README. <a href="/texts/">Texts</a> holds short and long-form writing.
      <a href="/creations/">Creations</a> holds media and projects. <a href="/tags/">Tags</a>
      cuts across both.
    </p>

    <div class="section-title">
      <h2>Recent Texts</h2>
    </div>
    <ul class="readme-list">
      {recentTexts.map((entry) => <li><a href={`/texts/${entry.slug}/`}>{entry.data.title}</a></li>)}
    </ul>

    <div class="section-title">
      <h2>Recent Creations</h2>
    </div>
    <ul class="readme-list">
      {recentCreations.map((entry) => <li><a href={`/creations/${entry.slug}/`}>{entry.data.title}</a></li>)}
    </ul>
  </article>
</BaseLayout>

<style>
  .readme-page {
    display: grid;
    gap: 1rem;
  }

  .readme-figure {
    margin-bottom: 0.5rem;
  }

  .readme-list {
    margin: 0;
    padding-left: 1.2rem;
  }
</style>
