---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";
---

<BaseLayout fileLabel="README">
  <article class="content-area about-page">
    <figure class="about-figure media-frame">
      <img
        src="/media/about/magnus-profile.webp"
        alt="Pixelated portrait of Magnus Lislevatn"
        loading="eager"
      />
    </figure>
    <ul class="about-socials" aria-label="Social media accounts">
      {siteConfig.socialLinks.map((link) => (
        <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
      ))}
    </ul>
    <p class="about-credit">
      Thanks to <a href="https://robinrendle.com/" target="_blank" rel="noreferrer">Robin Rendle</a>
      for the site inspiration.
    </p>
  </article>
</BaseLayout>

<style>
  .about-page {
    min-height: 100%;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 1.25rem;
  }

  .about-figure {
    width: min(100%, 25rem);
    margin: 0;
  }

  .about-figure img {
    width: 100%;
    aspect-ratio: 17 / 23;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .about-socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
  }

  .about-socials a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.28rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--panel-2) 90%, transparent 10%);
    text-decoration: none;
  }

  .about-socials a:hover {
    border-color: var(--line-strong);
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-soft) 72%, var(--panel) 28%);
  }

  .about-credit {
    margin: 0;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.8rem;
    color: var(--text-soft);
    text-align: center;
  }

  .about-credit a {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  @media (max-width: 720px) {
    .about-page {
      align-content: start;
    }
  }
</style>
