<style>
  .about-page {
    min-height: 100%;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 1.25rem;
  }

  .about-figure {
    width: min(100%, 25rem);
    margin: 0;
  }

  .about-figure img {
    width: 100%;
    aspect-ratio: 17 / 23;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .about-socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .social-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  .about-socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--panel-2) 90%, transparent 10%);
    text-decoration: none;
    font-size: 0.82rem;
  }

  .about-socials a:hover {
    border-color: var(--line-strong);
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-soft) 72%, var(--panel) 28%);
  }


  @media (max-width: 720px) {
    .about-page {
      align-content: start;
    }
  }
</style>
