---
import EntryCard from "../../../components/EntryCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPublishedCreations, groupEntriesByYear } from "../../../lib/content";

export async function getStaticPaths() {
  const creations = getPublishedCreations();
  const grouped = groupEntriesByYear(creations);
  return Object.entries(grouped).map(([year, entries]) => ({
    params: { year },
    props: { year, entries },
  }));
}

const { year, entries } = Astro.props;
---

<BaseLayout
  title={`Creations ${year}`}
  description={`Creations from ${year}.`}
  fileLabel={`Creations ${year}`}
>
  <section class="content-area">
    <p>Creation archive for <strong>{year}</strong>.</p>
    <div class="stack listing-grid">
      {entries.map((entry) => <EntryCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
