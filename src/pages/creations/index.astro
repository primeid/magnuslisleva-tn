---
import ArchiveGroup from "../../components/ArchiveGroup.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedCreations, groupEntriesByYear } from "../../lib/content";

const creations = getPublishedCreations();
const grouped = groupEntriesByYear(creations);
---

<BaseLayout title="Creations" description="Media, software, and projects." fileLabel="Creations">
  <section class="content-area">
    <p>
      Creations is for work that is primarily media or software rather than prose: music, apps,
      videos, photos, podcasts, and event pages.
    </p>
    {
      creations.length > 0 ? (
        <>
          <div class="years mono">
            {Object.keys(grouped).map((year) => <a href={`/creations/archive/${year}/`}>{year}</a>)}
          </div>
          {Object.entries(grouped).map(([year, entries]) => <ArchiveGroup year={year} entries={entries} />)}
        </>
      ) : (
        <p class="mono empty-state">No creations published yet.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .years {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.5rem 0 1rem;
  }

  .years a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .empty-state {
    color: var(--text-soft);
    font-size: 0.82rem;
  }
</style>
