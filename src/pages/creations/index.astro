---
import ArchiveGroup from "../../components/ArchiveGroup.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedCreations, groupEntriesByYear } from "../../lib/content";

const creations = getPublishedCreations();
const grouped = groupEntriesByYear(creations);
---

<BaseLayout title="Creations" description="Media, software, and projects.">
  <section class="shell listing">
    <div class="heading">
      <p class="eyebrow">Creations</p>
      <h1>Music, apps, video, podcasts, photos, and other releases.</h1>
      <p class="summary">
        This section is for work that is primarily media or software rather than writing.
      </p>
    </div>

    <div class="years mono">
      {Object.keys(grouped).map((year) => <a href={`/creations/archive/${year}/`}>{year}</a>)}
    </div>

    {Object.entries(grouped).map(([year, entries]) => <ArchiveGroup year={year} entries={entries} />)}
  </section>
</BaseLayout>

<style>
  .listing {
    padding-bottom: 4rem;
  }

  .heading {
    padding: 2rem 0;
  }

  h1 {
    margin: 0.55rem 0 0.7rem;
    font-size: clamp(2.8rem, 8vw, 5rem);
    line-height: 0.95;
    max-width: 12ch;
  }

  .summary {
    max-width: 38rem;
    margin: 0;
    color: var(--text-soft);
  }

  .years {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.25rem 0 1.75rem;
  }

  .years a {
    text-decoration: none;
    color: var(--text-soft);
    font-size: 0.82rem;
  }
</style>
