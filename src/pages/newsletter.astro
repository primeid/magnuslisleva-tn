---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";

const configured = siteConfig.mailchimpAction.length > 0;
---

<BaseLayout title="Newsletter" description="Join the mailing list." fileLabel="Newsletter">
  <section class="content-area newsletter-page">
    <p>
      Newsletter signup is intentionally separate from the rest of the archive. Add the Mailchimp
      form action in `src/site.config.ts` and this page will submit directly to your list.
    </p>

    <div class="signup">
      {
        configured ? (
          <form action={siteConfig.mailchimpAction} method="post" target="_blank" novalidate>
            <label for="email" class="mono">Email</label>
            <input id="email" type="email" name="EMAIL" required placeholder="you@example.com" />
            <button type="submit">Join the list</button>
          </form>
        ) : (
          <div class="placeholder">
            <p class="mono">Mailchimp not configured yet.</p>
            <p>Set `mailchimpAction` in `src/site.config.ts` to the exact Mailchimp form action URL.</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .signup {
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel-2);
  }

  form {
    display: grid;
    gap: 0.8rem;
  }

  label {
    font-size: 0.78rem;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  input,
  button {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font: inherit;
  }

  input {
    padding: 0.9rem 1rem;
    background: var(--panel);
  }

  button {
    padding: 0.9rem 1rem;
    background: var(--accent);
    color: white;
    cursor: pointer;
  }
</style>
