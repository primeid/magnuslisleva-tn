---
import type { Entry } from "../lib/content";
import { getEntryUrl } from "../lib/content";
import TagList from "./TagList.astro";

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const href = getEntryUrl(entry);
const isCreation = entry.collection === "creations";
---

<article class="entry-card">
  <div class="entry-main">
    <div class="entry-heading">
      <span class="entry-kind mono">{isCreation ? "MED" : "TXT"}</span>
      <h3>
        <a href={href}>{entry.data.title}</a>
      </h3>
    </div>
    <p>{entry.data.excerpt}</p>
    <div class="entry-foot">
      <span class="mono">{entry.data.publishDate.getFullYear()}</span>
      <TagList tags={entry.data.tags} />
    </div>
  </div>
</article>

<style>
  .entry-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    padding: 0.75rem;
  }

  .entry-main {
    display: grid;
    gap: 0.5rem;
  }

  .entry-heading {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
  }

  .entry-kind {
    color: var(--text-soft);
    font-size: 0.72rem;
    flex-shrink: 0;
  }

  h3 {
    margin: 0;
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.35;
  }

  h3 a {
    text-decoration: none;
  }

  p {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .entry-foot {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.15rem;
  }

  .entry-foot .mono {
    font-size: 0.75rem;
    color: var(--text-soft);
    flex-shrink: 0;
  }

  @media (max-width: 720px) {
    .entry-heading,
    .entry-foot {
      flex-direction: column;
      align-items: start;
    }
  }
</style>
