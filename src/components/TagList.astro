---
import { slugifyTag } from "../lib/content";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="tags">
      {tags.map((tag) => <a class="tag" href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>)}
    </div>
  )
}

<style>
  .tags {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }
</style>
