---
import type { Entry } from "../lib/content";
import EntryCard from "./EntryCard.astro";

interface Props {
  year: string;
  entries: Entry[];
}

const { year, entries } = Astro.props;
---

<section class="archive-group">
  <div class="year mono">{year}</div>
  <div class="entries listing-grid">
    {entries.map((entry) => <EntryCard entry={entry} />)}
  </div>
</section>

<style>
  .archive-group {
    display: grid;
    grid-template-columns: 3.5rem minmax(0, 1fr);
    gap: 0.5rem 0.75rem;
    padding: 0.5rem 0 0.75rem;
  }

  .year {
    padding-top: 0.65rem;
    color: var(--text-soft);
    font-size: 0.78rem;
  }

  @media (max-width: 720px) {
    .archive-group {
      grid-template-columns: 1fr;
    }
  }
</style>
